{
  "mcpServers": {
    "vision-mcp": {
      "type": "stdio",
      "command": "vision-mcp",
      "env": {
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_VISION_MODEL": "gemma4:31b-cloud"
      }
    },
    "grok-acp": {
      "type": "stdio",
      "command": "node",
      "args": ["$HOME/.factory/mcp-bridges/acp-bridge/index.mjs"],
      "env": {
        "ACP_COMMAND": "grok",
        "ACP_ARGS": "[\"agent\",\"stdio\"]",
        "ACP_LABEL": "Grok Build (xAI)",
        "ACP_SERVER_NAME": "grok-acp"
      },
      "timeoutMs": 300000
    },
    "cursor-acp": {
      "type": "stdio",
      "command": "node",
      "args": ["$HOME/.factory/mcp-bridges/acp-bridge/index.mjs"],
      "env": {
        "ACP_COMMAND": "cursor-agent",
        "ACP_ARGS": "[\"acp\"]",
        "ACP_AUTH_METHOD": "cursor_login",
        "ACP_LABEL": "Cursor Agent",
        "ACP_SERVER_NAME": "cursor-acp"
      },
      "timeoutMs": 300000
    }
  }
}
